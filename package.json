{
  "name": "pagefire",
  "version": "0.2.0",
  "description": "Self-hosted static publishing service — publish HTML/ZIP via MCP and get an instant HTTPS link",
  "private": true,
  "type": "module",
  "homepage": "https://pagefire.openhkt.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/bradyliuY/page-fire.git"
  },
  "keywords": ["mcp", "static-hosting", "self-hosted", "html", "publishing", "model-context-protocol"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && cp src/db/schema.sql dist/db/schema.sql && cp -r src/assets dist/assets",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "lint:quotes": "vitest run test/unit/html-templates.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "dompurify": "^3.1.6",
    "jsdom": "^24.1.1",
    "jszip": "^3.10.1",
    "marked": "^18.0.5",
    "yauzl": "^3.1.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.14.0",
    "@types/yauzl": "^2.10.3",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2",
    "vitest": "^3.2.6"
  },
  "bin": {
    "pagefire": "./dist/cli/index.js"
  },
  "pnpm": {
    "overrides": {
      "vite": ">=6.4.3",
      "esbuild": ">=0.25.0"
    }
  }
}
