{
  "name": "@openhkt/pagefire-mcp",
  "version": "0.1.0",
  "description": "stdio MCP connector for PageFire — bridges your MCP client to the hosted PageFire endpoint over Node's TLS stack, sidestepping client-runtime TLS quirks (e.g. Bun) and network fingerprint filtering.",
  "type": "module",
  "bin": {
    "pagefire-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.2"
  },
  "keywords": [
    "mcp",
    "pagefire",
    "model-context-protocol",
    "stdio",
    "publishing"
  ],
  "license": "MIT",
  "homepage": "https://pagefire.openhkt.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bradyliuY/page-fire.git",
    "directory": "packages/mcp-client"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
